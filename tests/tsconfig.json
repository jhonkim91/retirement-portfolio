{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["node", "vitest/globals", "@playwright/test"],
    "skipLibCheck": true
  },
  "include": [
    "./**/*.ts",
    "../frontend/src/server/market-data/**/*.ts",
    "../frontend/src/lib/analytics/**/*.js"
  ]
}
